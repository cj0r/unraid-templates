<?xml version="1.0"?>
<Container version="2">
  <Name>lftp-sync-manager</Name>
  <Repository>cj0r/lftp-sync-manager:latest</Repository>
  <Registry>https://hub.docker.com/r/cj0r/lftp-sync-manager</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/cj0r/lftp-sync-manager/issues</Support>
  <Project>https://github.com/cj0r/lftp-sync-manager</Project>
  <Overview>Dockerized LFTP Transfer Manager with a sleek Web GUI featuring real-time file watching, scheduled sync schedules, and automated SSH key handshakes.</Overview>
  <Category>Backup: Network:FTP</Category>
  <WebUI>http://[IP]:[PORT:9342]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/cj0r/unraid-templates/main/templates/lftp-sync-manager.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/cj0r/lftp-sync-manager/production/public/favicon.png</Icon>
  <Config Name="Web UI Port" Target="9342" Default="9342" Mode="port" Description="Web interface access port." Type="Port" Display="always" Required="true" Mask="false">9342</Config>
  <Config Name="App Configuration" Target="/config" Default="/mnt/user/appdata/lftp-sync-manager" Mode="rw" Description="Persistent configuration, history, and logs storage directory." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/lftp-sync-manager</Config>
  <Config Name="Local Upload Directory" Target="/local-push" Default="/mnt/user/appdata/lftp-sync-manager/upload" Mode="rw" Description="Local directory scanned for automatic file uploads." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/lftp-sync-manager/upload</Config>
  <Config Name="Local Download Directory" Target="/local-pull" Default="/mnt/user/appdata/lftp-sync-manager/download" Mode="rw" Description="Directory where files will be pulled from remote hosts." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/lftp-sync-manager/download</Config>
</Container>